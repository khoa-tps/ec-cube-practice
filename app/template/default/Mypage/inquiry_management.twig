{% extends 'default_frame.twig' %}

{% set body_class = 'inquiry_management' %}

{% set mypageno = 'inquiry' %}
    

{% block javascript %}
    <script src="//yubinbango.github.io/yubinbango/yubinbango.js" charset="UTF-8"></script>
{% endblock javascript %}

{% block main %}
    <div class="ec-layoutRole__main">
        <div class="ec-mypageRole">
            <div class="ec-pageHeader">
                <h1>{{ 'front.mypage.title'|trans }}/{{ 'front.mypage.nav__customer'|trans }}</h1>
            </div>
            {% include 'Mypage/navi.twig' %}
        </div>
        <button>
            <a href="{{ url('mypage_inquiry_create') }}">Create</a>
        </button>
        <div class="ec-mypageRole">
            <div class="ec-editRole">
                <div class="ec-off1Grid">
                    <div class="ec-off1Grid__cell">
                       <table class="table table-striped" style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                        <thead>
                            <tr style="background-color: #f8f9fa; border-bottom: 2px solid #dee2e6;">
                                <th style="padding: 12px; text-align: left; font-weight: 600; color: #495057;">No.</th>
                                <th style="padding: 12px; text-align: left; font-weight: 600; color: #495057;">Title</th>
                                <th style="padding: 12px; text-align: left; font-weight: 600; color: #495057;">Detail</th>
                                <th style="padding: 12px; text-align: left; font-weight: 600; color: #495057;">Email</th>
                                <th style="padding: 12px; text-align: center; font-weight: 600; color: #495057;">Status</th>
                                <th style="padding: 12px; text-align: left; font-weight: 600; color: #495057;">Created At</th>
                            </tr>
                        </thead>
                        <tbody> 
                        {% for Inquiry in Inquiries %}
                             <tr style="border-bottom: 1px solid #dee2e6; transition: background-color 0.2s;">
                             <td style="padding: 12px; vertical-align: middle;">{{ loop.index }}</td>
                             <td style="padding: 12px; vertical-align: middle; font-weight: 500;">{{ Inquiry.title }}</td>
                             <td style="padding: 12px; vertical-align: middle; max-width: 300px; word-wrap: break-word;">{{ Inquiry.detail|slice(0, 100) }}{% if Inquiry.detail|length > 100 %}...{% endif %}</td>
                             <td style="padding: 12px; vertical-align: middle;">{{ Inquiry.email }}</td>
                             <td style="padding: 12px; vertical-align: middle; text-align: center;">
                                 <span class="badge {% if Inquiry.status %}badge-success{% else %}badge-warning{% endif %}" 
                                       style="padding: 4px 8px; border-radius: 4px; font-size: 12px; font-weight: 500;
                                       {% if Inquiry.status %}background-color: #28a745; color: white;{% else %}background-color: #ffc107; color: #212529;{% endif %}">
                                     {{ Inquiry.status ? 'Completed' : 'Pending' }}
                                 </span>
                             </td>
                             <td style="padding: 12px; vertical-align: middle; font-size: 14px; color: #6c757d;">{{ Inquiry.createdAt|date('Y-m-d H:i') }}</td>
                             </tr>
                        {% else %}
                             <tr>
                                 <td colspan="6" style="padding: 40px; text-align: center; color: #6c757d; font-style: italic;">
                                     <div style="margin-bottom: 10px;">📝</div>
                                     No inquiries found. <a href="{{ url('mypage_inquiry_create') }}" style="color: #007bff; text-decoration: none;">Create your first inquiry</a>
                                 </td>
                             </tr>
                        {% endfor %}

                        </tbody>
                       </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
