{% extends 'default_frame.twig' %}

{% set body_class = 'coupon_management' %}

{% set mypageno = 'coupon' %}
    

{% block javascript %}
    <script src="//yubinbango.github.io/yubinbango/yubinbango.js" charset="UTF-8"></script>
{% endblock javascript %}

{% block main %}
    <div class="ec-layoutRole__main">
        <div class="ec-mypageRole">
            <div class="ec-pageHeader">
                <h1>{{ 'front.mypage.title'|trans }}/{{ 'front.mypage.nav__coupon'|trans }}</h1>
            </div>
            {% include 'Mypage/navi.twig' %}
        </div>
        <div class="ec-mypageRole">
            <div class="ec-editRole">
                <div class="ec-off1Grid">
                    <div class="ec-off1Grid__cell">
                       <table class="table table-striped" style="width: 100%; border-collapse: collapse; margin-bottom: 20px;">
                        <thead>
                            <tr style="background-color: #f8f9fa; border-bottom: 2px solid #dee2e6;">
                                <th style="padding: 12px; text-align: left; font-weight: 600; color: #495057;">No.</th>
                                <th style="padding: 12px; text-align: left; font-weight: 600; color: #495057;">Name</th>
                                <th style="padding: 12px; text-align: left; font-weight: 600; color: #495057;">Coupon Code</th>
                                <th style="padding: 12px; text-align: left; font-weight: 600; color: #495057;">Created At</th>
                                <th style="padding: 12px; text-align: left; font-weight: 600; color: #495057;">Available To</th>
                                <th style="padding: 12px; text-align: left; font-weight: 600; color: #495057;">Target Users</th>
                            </tr>
                        </thead>
                        <tbody> 
                        {% for item in Coupons %}
                            <tr style="border-bottom: 1px solid #dee2e6; transition: background-color 0.2s;">
                             <td style="padding: 12px; vertical-align: middle;">{{ loop.index }}</td>
                             <td style="padding: 12px; vertical-align: middle; font-weight: 500;">{{ item.coupon_name }}</td>
                             <td style="padding: 12px; vertical-align: middle; font-size: 14px; color: #6c757d;">{{ item.coupon_cd }}</td>
                             <td style="padding: 12px; vertical-align: middle; font-size: 14px; color: #6c757d;">{{ item.create_date|date('Y-m-d H:i') }}</td>
                             <td style="padding: 12px; vertical-align: middle; font-size: 14px; color: #6c757d;">{{ item.available_to_date|date('Y-m-d H:i') }}</td>
                             <td style="padding: 12px; vertical-align: middle; font-size: 14px; color: #6c757d;">
                                 {% set target_users_list = constant('Customize\\Config\\CouponConfig::TARGET_USERS_LIST') %}
                                 {% if item.target_users %}
                                     {% for val in item.target_users %}
                                         {{ target_users_list[val] }}{% if not loop.last %}, {% endif %}
                                     {% endfor %}
                                 {% endif %}
                             </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                       </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
