{% extends '@admin/default_frame.twig' %}
{% form_theme form '@admin/Form/bootstrap_4_horizontal_layout.html.twig' %}

{% set menus = ['product', 'product_feature'] %}

{% block title %}
	{{ 'admin.product.product_feature_management'|trans }}
{% endblock %}
{% block sub_title %}
	{{ 'admin.product.product_management'|trans }}
{% endblock %}

{% block main %}
	{{ form_start(form, { attr: { id: 'content_features_form' } }) }}
	<div class="c-contentsArea__cols">
		<div class="c-contentsArea__primaryCol">
			<div class="c-primaryCol">
				<div class="card rounded border-0 mb-4">
					<div class="card-header">
						<div class="row">
							<div class="col-8">
								<span class="card-title">特集詳細</span>
							</div>
						</div>
					</div>
					<div class="card-body">
						<div class="row mb-3">
							<label class="col-sm-2 col-form-label">特集名<i class="fa fa-question-circle fa-lg ms-1"></i>
							</label>
							<div class="col-sm-3">
								{{ form_widget(form.feature_name) }}
								{{ form_errors(form.feature_name) }}
							</div>
						</div>
						<div class="row mb-3">
							<label class="col-sm-2 col-form-label">ステータス<i class="fa fa-question-circle fa-lg ms-1"></i>
							</label>
							<div class="col-sm-3">
								{{ form_widget(form.status) }}
								{{ form_errors(form.status) }}
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	<div class="c-conversionArea">
		<div class="c-conversionArea__container">
			<div class="row justify-content-between align-items-center">
				<div class="col-6">
					<div class="c-conversionArea__leftBlockItem">
						<a class="c-baseLink" href="{{ url('admin_product_feature') }}">
							<i class="fa fa-backward" aria-hidden="true"></i>
							<span>{{ 'admin.product.product_feature_management'|trans }}</span>
						</a>
					</div>
				</div>
				<div class="col-6">
					<div class="row align-items-center justify-content-end">
						<div class="col-6">
                        <div id="ex-conversion-action" class="row align-items-center justify-content-end">
                            <div class="col-auto">
                                <button class="btn btn-ec-conversion px-5" type="submit">{{ 'admin.common.registration'|trans }}</button>
                            </div>
                        </div>
                    </div>
				</div>
			</div>
		</div>
	</div>
	{{ form_end(form) }}
{% endblock %}
