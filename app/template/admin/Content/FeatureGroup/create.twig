{% extends '@admin/default_frame.twig' %}
{% form_theme form '@admin/Form/bootstrap_4_horizontal_layout.html.twig' %}

{% set menus = ['content', 'features_group'] %}

{% block title %}
	{{ 'admin.content.features_group_management'|trans }}
{% endblock %}
{% block sub_title %}
	{{ 'admin.content.contents_management'|trans }}
{% endblock %}

{% block main %}
	{{ form_start(form, { attr: { id: 'content_features_form' } }) }}
	<div class="c-contentsArea__cols">
		<div class="c-contentsArea__primaryCol">
			<div class="c-primaryCol">
				<div class="card rounded border-0 mb-4">
					<div class="card-header">
						<div class="row">
							<div class="col-8">
								<span class="card-title">特集グループ詳細</span>
							</div>
						</div>
					</div>
					<div class="card-body">
						<div class="row mb-3">
							<label class="col-sm-4 col-form-label">公開日時<i class="fa fa-question-circle fa-lg ms-1"></i>
							</label>
							<div class="col-sm-8">
								<div class="row">
									<div class="col-sm-4">
										{{ form_widget(form.publish_date_from) }}
									</div>
									~
									<div class="col-sm-4">
										{{ form_widget(form.publish_date_to) }}
									</div>
								</div>
								{{ form_errors(form.publish_date_from) }}
								{{ form_errors(form.publish_date_to) }}
							</div>
						</div>
						<div class="row mb-3">
							<label class="col-sm-4 col-form-label">特集グループ名<i class="fa fa-question-circle fa-lg ms-1"></i>
							</label>
							<div class="col-sm-8">
								{{ form_widget(form.name) }}
								{{ form_errors(form.name) }}
							</div>
						</div>
						<div class="row mb-3">
							<label class="col-sm-4 col-form-label">説明<i class="fa fa-question-circle fa-lg ms-1"></i></label>
							<div class="col-sm-8">
								<div id="description" style="height: 360px" class="form-control{{ has_errors(form.description) ? ' is-invalid' }}"></div>
								<div style="display: none">{{ form_widget(form.description) }}</div>
								{{ form_errors(form.description) }}
							</div>
						</div>
						<div class="row mb-3">
							<label class="col-sm-4 col-form-label">特集<i class="fa fa-question-circle fa-lg ms-1"></i>
							</label>
							<div class="col-sm-8">
								<div class="mb-3">
									<div class="input-group">
										<div class="input-group-text">
											<span id="basic-addon1">
												<i class="fa fa-search"></i>
											</span>
										</div>
										<input id="search-category" class="form-control" type="search"
											placeholder="{{ 'admin.product.search_category'|trans }}"
											aria-label="Search">
									</div>
								</div>
								<div class="c-directoryTree--register rounded border mb-3 p-3">
									<ul class="list-unstyled">
										{% for feature in features %}
											<li class="c-directoryTree--registerItem category-li">
												<input type="checkbox" id="feature_{{ feature.id }}" class="related-category-checkbox" value="{{ feature.id }}" {% if ChoicedIds is defined and feature.id in ChoicedIds %}checked{% endif %}>
												<label for="feature_{{ feature.id }}">{{ feature.title }}</label>
											</li>
										{% endfor %}
									</ul>
									{% if form.related_category_ids is defined %}
										<div style="display:none;">
											{{ form_widget(form.related_category_ids) }}
										</div>
										{{ form_errors(form.related_category_ids) }}
									{% endif %}
								</div>
							
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	<div class="c-conversionArea">
		<div class="c-conversionArea__container">
			<div class="row justify-content-between align-items-center">
				<div class="col-6">
					<div class="c-conversionArea__leftBlockItem">
						<a class="c-baseLink" href="{{ url('admin_content_features') }}">
							<i class="fa fa-backward" aria-hidden="true"></i>
							<span>{{ 'admin.content.features_management'|trans }}</span>
						</a>
					</div>
				</div>
				<div class="col-6">
					<div class="row align-items-center justify-content-end">
						<div class="col-6">
                        <div id="ex-conversion-action" class="row align-items-center justify-content-end">
                            <div class="col-auto">
                                <button class="btn btn-ec-conversion px-5" type="submit">{{ 'admin.common.registration'|trans }}</button>
                            </div>
                        </div>
                    </div>
				</div>
			</div>
		</div>
	</div>
	{{ form_end(form) }}
{% endblock %}

{% block javascript %}
<script>
$(function() {
	$('#search-category').on('input', function () {
		searchWord($(this).val(), $('.category-li'));
	});

	ace.require('ace/ext/language_tools');
	var editor = ace.edit('description');
	editor.session.setMode('ace/mode/text');
	editor.setTheme('ace/theme/tomorrow');
	editor.setValue('{{ form.description.vars.value|default('')|escape('js') }}');
	editor.setOptions({
		showInvisibles: true
	});

	$("#description").resizable({
		resize: function () {
			editor.resize();
		}
	});

	$('#content_features_form').on('submit', function() {
		const ids = $('.related-category-checkbox:checked')
			.map(function () { return $(this).val(); })
			.get();
		$('#form_description').val(editor.getValue());
		$('#form_related_category_ids').val(ids.join(','));
	});
});
</script>
{% endblock %}
