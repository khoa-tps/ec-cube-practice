{% extends '@admin/default_frame.twig' %}

{% set menus = ['content', 'features_group'] %}

{% block title %}
	{{ 'admin.content.features_group_management'|trans }}
{% endblock %}
{% block sub_title %}
	{{ 'admin.content.contents_management'|trans }}
{% endblock %}

{% block main %}
	<div class="c-contentsArea__cols">
		<div class="c-contentsArea__primaryCol">
			<div class="c-primaryCol">
				<div class="d-block mb-3">
					<a class="btn btn-ec-regular" href="{{ url('admin_content_features_group_create') }}">
						{{ 'admin.common.create__new'|trans }}
					</a>
				</div>
				<div class="card rounded border-0 mb-4">
					<div class="card-header">
						<span class="card-title">{{ 'admin.content.features_management'|trans }}</span>
					</div>
					<div class="card-body p-0">
						<div class="table-responsive">
							<table class="table table-striped mb-0">
								<thead>
									<tr>
										<th class="ps-3">ID</th>
										<th>公開日時</th>
										<th>タイトル</th>
										<th>特集カウント</th>
										<th></th>
										<th></th>
									</tr>
								</thead>
								<tbody>
									{% for featureGroup in featureGroups %}
										<tr>
											<td class="ps-3">{{ featureGroup.id }}</td>
											<td>{{ featureGroup.publish_date_from|date('Y-m-d H:i:s') }}
												~
												{{ featureGroup.publish_date_to|date('Y-m-d H:i:s') }}</td>
											<td>{{ featureGroup.name }}</td>
											<td></td>
											<td>
												<a class="btn btn-ec-actionIcon action-down me-2 " href="" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="下へ" data-bs-original-title="下へ">
													<i class="fa fa-arrow-down fa-lg text-secondary">
														<i></a>
														<a class="btn btn-ec-actionIcon action-up me-2 " href="" data-bs-toggle="tooltip" data-bs-placement="top" aria-label="上へ" data-bs-original-title="上へ">
															<i class="fa fa-arrow-up fa-lg text-secondary"></i>
														</a>
														<a class="btn btn-ec-regular" href="{{ url('admin_content_features_group_edit', { id: featureGroup.id }) }}">
															<i class="fa fa-pencil"></i>
														</a>
													</td>
													<td>
														<a class="btn btn-ec-regular" href="{{ url('admin_content_features_group_delete', { id: featureGroup.id }) }}">
															<i class="fa fa-trash"></i>
														</a>
													</td>
												</tr>
											{% endfor %}
										</tr>
									</tbody>
								</tbody>
							</table>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
{% endblock %}
