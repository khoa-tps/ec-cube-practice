{% extends '@admin/default_frame.twig' %}
{% form_theme form '@admin/Form/bootstrap_4_horizontal_layout.html.twig' %}

{% set menus = ['content', 'features'] %}

{% block title %}{{ 'admin.content.features_management'|trans }}{% endblock %}
{% block sub_title %}{{ 'admin.content.contents_management'|trans }}{% endblock %}

{% block main %}
    {{ form_start(form, { attr: { id: 'content_mall_form' } }) }}
    <div class="c-contentsArea__cols">
        <div class="c-contentsArea__primaryCol">
            <div class="c-primaryCol">
                <div class="card rounded border-0 mb-4">
                    <div class="card-header">
                        <div class="row">
                            <div class="col-8"><span class="card-title">特集登録</span></div>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">公開日<i class="fa fa-question-circle fa-lg ms-1"></i></label>
                            <div class="col-sm-9">
                                {{ form_widget(form.publish_date_from) }} ~ {{ form_widget(form.publish_date_to) }}
                                {{ form_errors(form.publish_date_from) }}
                                {{ form_errors(form.publish_date_to) }}
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">タイトル<i class="fa fa-question-circle fa-lg ms-1"></i></label>
                            <div class="col-sm-9">
                                {{ form_widget(form.title) }}
                                {{ form_errors(form.title) }}
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">関連カテゴリ<i class="fa fa-question-circle fa-lg ms-1"></i></label>
                            <div class="col-sm-9">
                                {{ form_widget(form.related_category_ids) }}
                                {{ form_errors(form.related_category_ids) }}
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">キーワード<i class="fa fa-question-circle fa-lg ms-1"></i></label>
                            <div class="col-sm-9">
                                {{ form_widget(form.keywords) }}
                                {{ form_errors(form.keywords) }}
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label">サムネイル<i class="fa fa-question-circle fa-lg ms-1"></i></label>
                            <div class="col-sm-9 filepond-container">
                                {{ form_widget(form.thumbnail) }}
                                {{ form_errors(form.thumbnail) }}
                            </div>
                        </div>
                        {{ form_rest(form) }}
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="c-conversionArea">
        <div class="c-conversionArea__container">
            <div class="row justify-content-between align-items-center">
                <div class="col-6">
                    <div class="c-conversionArea__leftBlockItem">
                        <a class="c-baseLink" href="{{ url('admin_content_features') }}">
                            <i class="fa fa-backward" aria-hidden="true"></i>
                            <span>{{ 'admin.content.features_management'|trans }}</span>
                        </a>
                    </div>
                </div>
                <div class="col-6">
                    <div class="row align-items-center justify-content-end">
                        <div class="col-auto">
                            <span class="badge bg-success">ステータス: 公開(デフォルト)</span>
                        </div>
                        <div class="col-auto">
                            <button id="save-button" class="btn btn-ec-conversion px-5" type="submit">{{ 'admin.common.registration'|trans }}</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {{ form_end(form) }}
{% endblock %}
