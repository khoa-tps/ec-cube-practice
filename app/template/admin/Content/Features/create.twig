{% extends '@admin/default_frame.twig' %}
{% form_theme form '@admin/Form/bootstrap_4_horizontal_layout.html.twig' %}

{% set menus = ['content', 'features'] %}

{% block title %}
	{{ 'admin.content.features_management'|trans }}
{% endblock %}
{% block sub_title %}
	{{ 'admin.content.contents_management'|trans }}
{% endblock %}

{% block main %}
	{{ form_start(form, { attr: { id: 'content_features_form' } }) }}
	<div class="c-contentsArea__cols">
		<div class="c-contentsArea__primaryCol">
			<div class="c-primaryCol">
				<div class="card rounded border-0 mb-4">
					<div class="card-header">
						<div class="row">
							<div class="col-8">
								<span class="card-title">特集登録</span>
							</div>
						</div>
					</div>
					<div class="card-body">
						<div class="row mb-3">
							<label class="col-sm-4 col-form-label">公開日<i class="fa fa-question-circle fa-lg ms-1"></i>
							</label>
							<div class="col-sm-8">
								<div class="row">
									<div class="col-sm-4">
										{{ form_widget(form.publish_date_from) }}
									</div>
									~
									<div class="col-sm-4">
										{{ form_widget(form.publish_date_to) }}
									</div>
								</div>
								{{ form_errors(form.publish_date_from) }}
								{{ form_errors(form.publish_date_to) }}
							</div>
						</div>
						<div class="row mb-3">
							<label class="col-sm-4 col-form-label">タイトル<i class="fa fa-question-circle fa-lg ms-1"></i>
							</label>
							<div class="col-sm-8">
								{{ form_widget(form.title) }}
								{{ form_errors(form.title) }}
							</div>
						</div>
						<div class="row mb-3">
							<label class="col-sm-4 col-form-label">関連カテゴリ<i class="fa fa-question-circle fa-lg ms-1"></i>
							</label>
							<div class="col-sm-8">
								<div class="mb-3">
									<div class="input-group">
										<div class="input-group-text">
											<span id="basic-addon1">
												<i class="fa fa-search"></i>
											</span>
										</div>
										<input id="search-category" class="form-control" type="search"
											placeholder="{{ 'admin.product.search_category'|trans }}"
											aria-label="Search">
									</div>
								</div>

								{% macro tree(ChoicedIds, Category, form) %}
									{% import _self as selfMacro %}
									<li class="c-directoryTree--registerItem category-li">
										<input type="checkbox" id="feature_category_{{ Category.id }}" class="related-category-checkbox" value="{{ Category.id }}" {% if Category.id in ChoicedIds %}checked{% endif %}>
										<label for="feature_category_{{ Category.id }}">{{ Category.name }}</label>
										<ul class="list-unstyled">
											{% for child,ChildCategory in Category.children %}
												{{ selfMacro.tree(ChoicedIds, ChildCategory, form) }}
											{% endfor %}
										</ul>
									</li>
								{% endmacro %}

								<div class="c-directoryTree--register rounded border mb-3 p-3">
									{% import _self as renderMacro %}
									{% for TopCategory in TopCategories %}
										<ul class="list-unstyled">
											{{ renderMacro.tree(ChoicedCategoryIds, TopCategory, form.related_category_ids) }}
										</ul>
									{% endfor %}
									<div style="display:none;">
										{{ form_widget(form.related_category_ids) }}
									</div>
									{{ form_errors(form.related_category_ids) }}
								</div>
							</div>
						</div>
						<div class="row mb-3">
							<label class="col-sm-3 col-form-label">キーワード<i class="fa fa-question-circle fa-lg ms-1"></i>
							</label>
							<div class="col-sm-9">
								<div id="keyword-tags" class="mb-2"></div>
								<input id="keyword-input" type="text" class="form-control" placeholder="キーワードをカンマで区切って入力してください">
								<div style="display:none;">
									{{ form_widget(form.keywords) }}
								</div>
								{{ form_errors(form.keywords) }}
							</div>
						</div>
						<div class="row">
							<div class="col-3">
								<div class="d-inline-block" data-bs-toggle="tooltip" data-bs-placement="top" title="{{ 'tooltip.product.image'|trans }}">
									<span>{{ 'admin.product.image'|trans }}</span>
									<i class="fa fa-question-circle fa-lg ms-1"></i>
									<br>{{ 'admin.product.image_size'|trans }}
								</div>
							</div>
							<div class="col mb-2">
								<p id="message"></p>
								<div id="upload-zone" class="rounded">
									{{ form_widget(form.thumbnail, { attr : { style : 'display:none;' } }) }}
									{{ form_errors(form.thumbnail) }}
								</div>
								<span class="invalid-feedback" id="thumbnail_error" style="display: none">
									<span class="d-block">
										<span class="form-error-icon badge bg-danger text-uppercase">{{ 'Error'|trans({}, 'validators') }}</span>
										<span class="form-error-message"></span>
									</span>
								</span>
							</div>
						</div>
						<div class="row mb-3">
							<label class="col-sm-3 col-form-label">説明<i class="fa fa-question-circle fa-lg ms-1"></i></label>
							<div class="col-sm-9">
								<div id="description" style="height: 360px" class="form-control{{ has_errors(form.description) ? ' is-invalid' }}"></div>
								<div style="display: none">{{ form_widget(form.description) }}</div>
								{{ form_errors(form.description) }}
							</div>
						</div>
						<div class="row mb-3">
							<label class="col-sm-3 col-form-label">キャッチフレーズ<i class="fa fa-question-circle fa-lg ms-1"></i></label>
							<div class="col-sm-9">
								<div id="catchphrase" style="height: 360px" class="form-control{{ has_errors(form.catchphrase) ? ' is-invalid' }}"></div>
								<div style="display: none">{{ form_widget(form.catchphrase) }}</div>
								{{ form_errors(form.catchphrase) }}
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	<div class="c-conversionArea">
		<div class="c-conversionArea__container">
			<div class="row justify-content-between align-items-center">
				<div class="col-6">
					<div class="c-conversionArea__leftBlockItem">
						<a class="c-baseLink" href="{{ url('admin_content_features') }}">
							<i class="fa fa-backward" aria-hidden="true"></i>
							<span>{{ 'admin.content.features_management'|trans }}</span>
						</a>
					</div>
				</div>
				<div class="col-6">
					<div class="row align-items-center justify-content-end">
						<div class="col-auto">
							<span class="badge bg-success">ステータス: 公開(デフォルト)</span>
						</div>
						<div class="col-auto">
							<button id="save-button" class="btn btn-ec-conversion px-5" type="submit">{{ 'admin.common.registration'|trans }}</button>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	{{ form_end(form) }}
{% endblock %}

{% block javascript %}
<script>
$(function() {
    var inputFileElement = document.getElementById('{{ form.thumbnail.vars.id }}');
    if (inputFileElement) {
        {% if eccube_config.locale == 'ja' or eccube_config.locale == 'en' %}
        FilePond.setOptions(FilePondLocale_{{ eccube_config.locale }});
        {% endif %}

        FilePond.create(inputFileElement, {
            allowFileTypeValidation: true,
            acceptedFileTypes: ['image/gif', 'image/png', 'image/jpeg', 'image/webp'],
            allowFileSizeValidation: true,
            maxFileSize: 10000000,
            maxFiles: 1,
            allowBrowse: true,
            allowDrop: true,
            storeAsFile: true,
            instantUpload: false,
            allowProcess: false,
            labelIdle: '<i class="fa fa-cloud-upload fa-3x text-ec-lightGray mx-3 align-middle" aria-hidden="true" style="font-size: 40px"></i>{{ 'admin.common.drag_and_drop_image_description'|trans }}<span class="filepond--label-action">{{ 'admin.common.file_select'|trans }}</span>',
            styleItemPanelAspectRatio: 0.5625,
        });
    }

	$('#search-category').on('input', function () {
		searchWord($(this).val(), $('.category-li'));
	});

	 ace.require('ace/ext/language_tools');
        var editor = ace.edit('description');
        editor.session.setMode('ace/mode/text');
        editor.setTheme('ace/theme/tomorrow');
        editor.setValue('{{ form.description.vars.value|default('')|escape('js') }}');
        editor.setOptions({
            showInvisibles: true
        });

        $("#description").resizable({
            resize: function () {
                editor.resize();
            }
        });

        var editorCatchphrase = null;
        if (document.getElementById('catchphrase')) {
            editorCatchphrase = ace.edit('catchphrase');
            editorCatchphrase.session.setMode('ace/mode/text');
            editorCatchphrase.setTheme('ace/theme/tomorrow');
            editorCatchphrase.setValue('{{ form.catchphrase.vars.value|default('')|escape('js') }}');
            editorCatchphrase.setOptions({
                showInvisibles: true
            });

            $("#catchphrase").resizable({
                resize: function () {
                    editorCatchphrase.resize();
                }
            });
        }

        $('#content_features_form').on('submit', function() {
			const ids = $('.related-category-checkbox:checked')
				.map(function () { return $(this).val(); })
				.get();
            $('#form_description').val(editor.getValue());
			$('#form_related_category_ids').val(ids.join(','));
			if (editorCatchphrase !== null) {
                $('#form_catchphrase').val(editorCatchphrase.getValue());
            }
        });


		const tags = [];
		const $input = $('#keyword-input');
		const $tags = $('#keyword-tags');
		const $hidden = $('#form_keywords');

		function renderTags() {
		$tags.empty();
		tags.forEach((tag, idx) => {
			$tags.append(`<span class="badge bg-secondary me-1">${tag} <a href="#" data-idx="${idx}" class="text-white ms-1">x</a></span>`);
		});
		$hidden.val(tags.join(','));
		}

		function addTag(value) {
		const v = value.trim();
		if (!v || tags.includes(v)) return;
		tags.push(v);
		renderTags();
		}

		$input.on('keydown', function (e) {
		if (e.key === 'Tab' || e.key === 'Enter' || e.key === ',') {
			e.preventDefault();
			addTag($input.val());
			$input.val('');
		}
		});

		$tags.on('click', 'a[data-idx]', function (e) {
		e.preventDefault();
		tags.splice(Number($(this).data('idx')), 1);
		renderTags();
		});
});
</script>
{% endblock %}
