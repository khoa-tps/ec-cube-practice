{% extends '@admin/default_frame.twig' %}

{% set menus = ['order', 'plugin_coupon'] %}

{% block title %}{{ 'plugin_coupon.admin.index.title'|trans }}{% endblock %}
{% block sub_title %}{{ 'plugin_coupon.admin.index.subtitle'|trans }}{% endblock %}

{% block main %}
    <div class="c-outsideBlock">
        <form id='search_form' method="post" action="{{ url('plugin_coupon_list') }}">
            {{ form_widget(searchForm._token) }}
            <div class="c-outsideBlock__contents">
                <div class="row justify-content-start">

                    <div class="col-6">
                        <div class="mb-2">
                            <label class="col-form-label" data-bs-toggle="tooltip" data-bs-placement="top" title="{{ 'tooltip.product.multi_search_label'|trans }}">{{ 'admin.product.multi_search_label'|trans }}<i class="fa fa-question-circle fa-lg ms-1"></i></label>
                            {{ form_widget(searchForm.id) }}
                            {{ form_errors(searchForm.id) }}
                        </div>
                        <div class="d-inline-block mb-3" data-bs-toggle="collapse" href="#searchDetail"
                             aria-expanded="false" aria-controls="searchDetail"><a><i
                                         class="fa fa-plus-square-o fw-bold me-1"></i><span
                                         class="fw-bold">{{ 'admin.common.search_detail'|trans }}</span></a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="c-subContents collapse ec-collapse" id="searchDetail">
                <div class="row mb-2">
                    <div class="col-6">
                        <div class="row mb-2">
                            <div class="col-12">
                                <p class="col-form-label">{{ 'plugin_coupon.admin.index.col04'|trans }}</p>
                                {{ form_widget(searchForm.coupon_type, {'label_attr': {'class': 'checkbox-inline'}}) }}
                                {{ form_errors(searchForm.coupon_type, {'label_attr': {'class': 'checkbox-inline'}}) }}
                            </div>
                        </div>
                        <div class="row mb-2">
                            <div class="col-12">
                                <p class="col-form-label">{{ 'admin.product.display_status'|trans }}</p>
                                {{ form_widget(searchForm.enable_flag, {'label_attr': {'class': 'checkbox-inline'}}) }}
                                {{ form_errors(searchForm.enable_flag, {'label_attr': {'class': 'checkbox-inline'}}) }}
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="mb-2">
                            <label class="col-form-label">
                                {{ 'admin.common.create_date'|trans }}
                            </label>
                            <div class="row align-items-center">
                                <div class="col">
                                    {{ form_widget(searchForm.create_datetime_start) }}
                                    {{ form_errors(searchForm.create_datetime_start) }}
                                </div>
                                <div class="col-auto text-center"><span>{{ 'admin.common.separator__range'|trans }}</span>
                                </div>
                                <div class="col">
                                    {{ form_widget(searchForm.create_datetime_end) }}
                                    {{ form_errors(searchForm.create_datetime_end) }}
                                </div>
                            </div>
                        </div>
                        <div class="mb-2">
                            <label class="col-form-label">{{ 'admin.common.update_date'|trans }}</label>
                            <div class="row align-items-center">
                                <div class="col">
                                    {{ form_widget(searchForm.update_datetime_start) }}
                                    {{ form_errors(searchForm.update_datetime_start) }}
                                </div>
                                <div class="col-auto"><span>{{ 'admin.common.separator__range'|trans }}</span></div>
                                <div class="col">
                                    {{ form_widget(searchForm.update_datetime_end) }}
                                    {{ form_errors(searchForm.update_datetime_end) }}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                {# エンティティ拡張の自動出力 #}
                {% for f in searchForm|filter(f => f.vars.eccube_form_options.auto_render) %}
                    <div class="row mb-2">
                        {% if f.vars.eccube_form_options.form_theme %}
                            {% form_theme f f.vars.eccube_form_options.form_theme %}
                            {{ form_row(f) }}
                        {% else %}
                            <div class="col">
                                <div class="mb-3">
                                    <label>{{ f.vars.label|trans }}</label>
                                    {{ form_widget(f) }}
                                    {{ form_errors(f) }}
                                </div>
                            </div>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
            <div class="c-outsideBlock__contents mb-5">
                <button class="btn btn-ec-conversion px-5" type="submit">{{ 'admin.common.search'|trans }}</button>
                <a href="{{ url('plugin_coupon_list') }}" class="btn btn-ec-sub px-5 ms-2">Reset</a>
                {% if pagination %}
                    <span class="fw-bold ms-2">{{ 'admin.common.search_result'|trans({"%count%":pagination.totalItemCount|number_format})|raw }}</span>
                {% endif %}
            </div>
            <div class="c-outsideBlock__contents mb-5">
                {{ include('@admin/search_items.twig', { 'form': searchForm }, ignore_missing = true) }}
            </div>
        </form>
    </div>

    <div class="row justify-content-between mb-2">
        <div class="col-11 text-end">
            <div class="d-inline-block">
                <div class="btn-group" role="group">
                    <a class="btn btn-ec-regular" href="{{ url('plugin_coupon_export') }}">
                        <i class="fa fa-cloud-download me-1 text-secondary"></i>
                        <span>{{ 'admin.common.csv_download'|trans }}</span>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="c-contentsArea__cols">
        <div class="c-contentsArea__primaryCol">
            <div class="c-primaryCol">
                <div class="card rounded border-0 mb-4">
                    <div class="card-header"><span class="normal">{{ 'plugin_coupon.admin.index.number'|trans({'%number%': Coupons.totalItemCount})|raw }}</span></div>
                    <div class="card-body p-0">
                            <table class="table table-sm table-hover">
                                <thead>
                                <tr>
                                    <th>{{ 'plugin_coupon.admin.index.col01'|trans }}</th>
                                    <th>{{ 'plugin_coupon.admin.index.col02'|trans }}</th>
                                    <th>{{ 'plugin_coupon.admin.index.col03'|trans }}</th>
                                    <th>{{ 'plugin_coupon.admin.index.col04'|trans }}</th>
                                    <th>{{ 'plugin_coupon.admin.index.col05'|trans }}</th>
                                    <th>{{ 'plugin_coupon.admin.index.col06'|trans }}</th>
                                    <th>{{ 'plugin_coupon.admin.index.col07'|trans }}</th>
                                    <th>{{ 'plugin_coupon.admin.index.col08'|trans }}</th>
                                    <th>{{ 'plugin_coupon.admin.index.col09'|trans }}</th>
                                    <th>{{ 'plugin_coupon.admin.index.col10'|trans }}</th>
                                    <th>{{ 'plugin_coupon.admin.index.col11'|trans }}</th>
                                    <th>{{ 'plugin_coupon.admin.index.col12'|trans }}</th>
                                </tr>
                                </thead>
                                <tbody>
                                {% for Coupon in Coupons %}
                                <tr class="{% if Coupon.enable_flag == 0 %}active{% endif %}">
                                    <td class="coupon_id">{{ Coupon.id }}</td>
                                    <td class="coupon_cd">{{ Coupon.coupon_cd }}</td>
                                    <td class="coupon_name">{{ Coupon.coupon_name }}</td>
                                    {% if Coupon.coupon_type == 1 %}
                                        <td class="coupon_type">{{ 'plugin_coupon.admin.coupon_type.product'|trans }}</td>
                                    {% elseif Coupon.coupon_type == 2 %}
                                        <td class="coupon_type">{{ 'plugin_coupon.admin.coupon_type.category'|trans }}</td>
                                    {% elseif Coupon.coupon_type == 3 %}
                                        <td class="coupon_type">{{ 'plugin_coupon.admin.coupon_type.all'|trans }}</td>
                                    {% else %}
                                        <td class="coupon_type"></td>
                                    {% endif %}

                                    {% if Coupon.coupon_member == 1 %}
                                        <td class="coupon_member">{{ 'plugin_coupon.admin.coupon_member.yes'|trans }}</td>
                                    {% else %}
                                        <td class="coupon_member">{{ 'plugin_coupon.admin.coupon_member.no'|trans }}</td>
                                    {% endif %}

                                    {% if Coupon.discount_type == 1 %}
                                        <td class="coupon_discount">{{ Coupon.discount_price|price }}</td>
                                    {% elseif Coupon.discount_type == 2 %}
                                        <td class="coupon_discount">{{ Coupon.discount_rate }} %</td>
                                    {% else %}
                                        <td class="coupon_discount"></td>
                                    {% endif %}

                                    <td>{{ Coupon.coupon_use_time|number_format }} / {{ Coupon.coupon_release|number_format }}</td>
                                    <td>{{ Coupon.coupon_lower_limit|price }}</td>
                                    <td>{{ Coupon.available_from_date|date_format }} ～ {{ Coupon.available_to_date|date_format }}</td>

                                    <td><a href="{{ url('plugin_coupon_edit', { id: Coupon.id }) }}">{{ 'admin.common.edit'|trans }}</a></td>
                                    <td>
                                        <a href="{{ url('plugin_coupon_enable', { id: Coupon.id }) }}" {{ csrf_token_for_anchor() }} data-confirm="false" data-method="put">
                                        {% if Coupon.enable_flag == 1 %}
                                            {{ 'common.enabled'|trans }}
                                        {% else %}
                                            {{ 'common.disabled'|trans }}
                                        {% endif %}
                                        </a>
                                    </td>
                                    <td>
                                        <a class="" data-bs-toggle="modal" data-bs-target="#confirmModal-{{ Coupon.id }}" data-bs-tooltip="tooltip" data-bs-placement="top" title="{{ 'common.delete'|trans }}">
                                            <i class="fa fa-close fa-lg text-secondary"></i>
                                        </a>

                                        <div class="modal fade" id="confirmModal-{{ Coupon.id }}" tabindex="-1"
                                             role="dialog"
                                             aria-labelledby="confirmModal-{{ Coupon.id }}" aria-hidden="true">
                                            <div class="modal-dialog" role="document">
                                                <div class="modal-content">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title fw-bold">
                                                            {{ 'plugin_coupon.admin.index.delete__confirm_title'|trans }}</h5>
                                                        <button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <div class="modal-body text-start">
                                                        <p class="text-start">
                                                            {{ 'plugin_coupon.admin.index.delete__confirm_message'|trans }}</p>
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button class="btn btn-ec-sub" type="button"
                                                                data-bs-dismiss="modal">{{ 'common.cancel'|trans }}
                                                        </button>
                                                        <a href="{{ url('plugin_coupon_delete', {'id' : Coupon.id}) }}" class="btn btn-ec-delete" data-confirm="false" {{ csrf_token_for_anchor() }} data-method="delete">
                                                            {{ 'common.delete'|trans }}
                                                        </a>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                    </td>
                                </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                    </div>
                </div>

                {% if Coupons.totalItemCount > 0 %}
                    <div class="row justify-content-md-center mb-4 pb-4">
                        {% include "@admin/pager.twig" with { 'pages' : Coupons.paginationData, 'routes' : 'plugin_coupon_list' } %}
                    </div>
                {% endif %}
            </div>

            <div class="card rounded border-0">
                <div class="card-body p-4">
                    <div class="text-center">
                        <a href="{{ url('plugin_coupon_new') }}" class="btn btn-ec-regular ps-4 pe-4">{{ 'plugin_coupon.admin.index.create_button'|trans }}</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
{% endblock %}
